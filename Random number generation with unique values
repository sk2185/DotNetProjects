C#
==

Random rnd = new Random();
 Int32 count = 400000;
 List<String> uniqueNumbers = Enumerable.Range(100000, 900000) 
 .OrderBy(x=> rnd.Next())
 .Select(x=> x.ToString())
 .Take(count)
 .ToList();
 
 for(int i =0; i<= uniqueNumbers.Count()-1; i++)
 {
 Console.WriteLine(uniqueNumbers[i]);
 }

